# TrainYourAgent — environment variables (Vercel project settings)
# Copy this file to .env.local for dev. Set the same keys in Vercel dashboard for production.

# ---- AI Chat + Agent Simulator (api/chat.ts) ------------------------------
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- Lead capture (api/lead.ts) -----------------------------------------
# Resend: https://resend.com/api-keys (free tier covers 3,000 emails/mo)
RESEND_API_KEY=re_...
# Optional: Slack webhook so leads ping you in Slack instantly
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Where lead notification emails go (default: hello@trainyouragent.com)
LEAD_NOTIFY_TO=hello@trainyouragent.com
# From address (must be a verified Resend sender domain)
LEAD_NOTIFY_FROM=leads@trainyouragent.com

# ---- Stripe Checkout (api/checkout.ts) ----------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Create products + prices in Stripe, paste price IDs here
STRIPE_PRICE_OPERATORS=price_...        # $799/mo subscription
STRIPE_PRICE_FOUNDERS_BUILD=price_...   # one-time build fee (optional)

# ---- Optional: Plausible Analytics ---------------------------------------
# If using Plausible self-hosted or custom domain, override below.
# VITE_PLAUSIBLE_DOMAIN=trainyouragent.com
# VITE_PLAUSIBLE_API=https://plausible.io/api/event
