# TrainYourAgent — environment variables
# Copy this file to .env.local for dev. Set the same keys in Vercel for production.
# NEVER commit .env.local. NEVER paste real values in this file.

# ============================================================================
# CLIENT-SIDE (VITE_*) — bundled into the browser. Public-safe values only.
# ============================================================================

# Supabase project URL — https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (publishable) key — safe to ship to the browser when RLS is on
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJI...

# Optional: Plausible Analytics override
# VITE_PLAUSIBLE_DOMAIN=trainyouragent.com
# VITE_PLAUSIBLE_API=https://plausible.io/api/event

# ============================================================================
# AI PROVIDERS (api/chat.ts) — multi-provider fallback chain
# Order: Anthropic -> Groq -> Gemini. At least one is required for /api/chat.
# ============================================================================

# Anthropic Claude — https://console.anthropic.com/settings/keys
# Optional; if unset, chain falls through to Groq.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Groq (free tier, Llama 3.3 70B) — https://console.groq.com/keys
# Recommended fallback; voice agent uses this by default.
GROQ_API_KEY=gsk_...

# Google Gemini 2.5 Flash (free tier) — https://aistudio.google.com/apikey
# Last-resort fallback.
GEMINI_API_KEY=AIza...

# ============================================================================
# SERVER-SIDE SECRETS — never bundled to client. Required in Vercel project env.
# ============================================================================

# Supabase service role key — server-only, full DB access
# https://app.supabase.com/project/_/settings/api
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...

# Admin dashboard gate — /admin UI and /api/admin/* endpoints
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# One-shot init token for /api/stripe-setup (creates products + prices)
# Generate with: openssl rand -hex 32; rotate after running once.
STRIPE_SETUP_INIT_TOKEN=

# ============================================================================
# STRIPE — Checkout + webhooks (api/checkout.ts, api/stripe-webhook.ts)
# ============================================================================

# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Price IDs — create products in Stripe, paste price IDs here
STRIPE_PRICE_OPERATORS=price_...        # $799/mo subscription
STRIPE_PRICE_FOUNDERS_BUILD=price_...   # one-time build fee (optional)

# Webhook signing secret — Dashboard -> Developers -> Webhooks -> your endpoint
# Used by api/stripe-webhook.ts to verify checkout.session.completed +
# invoice.payment_succeeded events before firing Purchase / Slack / Resend.
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# EMAIL + LEADS (api/lead.ts, api/booking-abandoned.ts)
# ============================================================================

# Resend — https://resend.com/api-keys (free tier covers 3,000 emails/mo)
RESEND_API_KEY=re_...

# Where lead notification emails go
LEAD_NOTIFY_TO=hello@trainyouragent.com

# From address (must be a verified Resend sender domain)
LEAD_NOTIFY_FROM=leads@trainyouragent.com

# Optional: Slack webhook so leads ping you in Slack instantly
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# WEBHOOKS (signature-verified inbound)
# ============================================================================

# Cal.com webhook signing secret (api/cal-webhook.ts)
# Cal dashboard -> Webhooks -> create endpoint -> copy secret
CAL_WEBHOOK_SECRET=

# ============================================================================
# NEWSLETTER (api/lead.ts, api/stripe-webhook.ts)
# ============================================================================

# beehiiv — https://app.beehiiv.com -> Settings -> Integrations -> API
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=pub_...

# ============================================================================
# ANALYTICS — Meta Pixel + Conversions API
# api/meta-event.ts, api/stripe-webhook.ts (server-side Purchase mirror)
# ============================================================================

# Pixel ID — Events Manager -> Settings (16-digit number).
# Set the SAME value in both VITE_META_PIXEL_ID (browser, build-time) and
# META_PIXEL_ID (server, runtime) so client-side fbq() and server-side CAPI
# events match per the Meta dedup spec.
VITE_META_PIXEL_ID=
META_PIXEL_ID=

# Conversion API access token — Events Manager -> Settings -> CAPI ->
# Generate access token. Server-only, never bundle to the browser.
# Either name is accepted (TOKEN is legacy, ACCESS_TOKEN is the v57a name).
META_CAPI_ACCESS_TOKEN=
META_CAPI_TOKEN=

# Optional: when set, every CAPI event is flagged as a test event so it shows
# up in Events Manager -> Test Events instead of production. Find this in
# Events Manager -> Test Events -> "Generate test event code".
META_TEST_EVENT_CODE=

# ============================================================================
# FRIDAY DIGEST CRON (api/friday-digest.ts)
# Vercel cron config in vercel.json fires GET /api/friday-digest every Friday
# at 13:00 UTC (9am ET). The cron call must include ?token=$ADMIN_TOKEN.
# ============================================================================

# Optional: GitHub PAT (raises the API rate limit when pulling commit lists).
# Public repo so a token isn't required, but adds headroom for large repos.
GITHUB_TOKEN=

# Optional override — defaults to "builderofages/trainyouragent"
GITHUB_DIGEST_REPO=builderofages/trainyouragent
